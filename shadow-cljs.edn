{:source-paths ["src" "test"]

 :dependencies [[reagent "1.2.0"]
                [org.clojure/test.check "1.1.1"]]

 :dev-http {3000 "public"}

 :builds
 {:app {:target     :browser
        :output-dir "public/js"
        :asset-path "/js"
        :modules    {:main {:init-fn tabletop.core/init}}}

  :test {:target    :node-test
         :output-to "out/test.js"
         :ns-regexp "-test$"}}}
