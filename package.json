{
  "name": "tabletop-simulator",
  "version": "0.1.0",
  "description": "Browser-based 2D tabletop simulator",
  "scripts": {
      "dev": "shadow-cljs watch app",
      "watch": "shadow-cljs watch app;",
      "build-gh": "rm -rf docs && npx shadow-cljs release app && mkdir -p docs && cp -r public/* docs && touch docs/.nojekyll",
      "build": "shadow-cljs release app",
      "css": "tailwindcss -i ./src/css/main.css -o ./public/css/style.css --watch",
      "test": "shadow-cljs compile test && node out/test.js"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "shadow-cljs": "^2.28.0",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0"
  }
}
